generator client {
  provider      = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  TEAM_LEADER
}

enum TaskStatus {
  DRAFT
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum AssignmentStatus {
  PENDING
  CONFIRMED
  DECLINED
  NO_RESPONSE
}

enum SmsDirection {
  OUTBOUND
  INBOUND
}

// ─── Core models ──────────────────────────────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users      User[]
  volunteers Volunteer[]
  categories Category[]
  teams      Team[]
  tasks      Task[]
  templates  TaskTemplate[]
}

model User {
  id             String    @id @default(cuid())
  name           String
  email          String    @unique
  emailVerified  DateTime?
  image          String?
  passwordHash   String?
  role           Role      @default(TEAM_LEADER)
  organizationId String
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  managedTeams Team[]       @relation("TeamLeader")
  createdTasks Task[]       @relation("TaskCreator")
  accounts     Account[]
  sessions     Session[]
  smsLogsSent  SmsLog[]     @relation("SentBy")
}

model Volunteer {
  id             String   @id @default(cuid())
  firstName      String
  lastName       String
  phone          String
  email          String?
  skills         String[]
  notes          String?
  isActive       Boolean  @default(true)
  optedOut       Boolean  @default(false)
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  teamMemberships TeamMembership[]
  assignments     Assignment[]
  smsLogs         SmsLog[]

  @@unique([organizationId, phone])
}

model TeamMembership {
  id          String @id @default(cuid())
  teamId      String
  volunteerId String

  team      Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  volunteer Volunteer @relation(fields: [volunteerId], references: [id], onDelete: Cascade)

  @@unique([teamId, volunteerId])
}

model Category {
  id             String   @id @default(cuid())
  name           String
  description    String?
  color          String   @default("#6366f1")
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  teams         Team[]
  tasks         Task[]
  taskTemplates TaskTemplate[]

  @@unique([organizationId, name])
}

model Team {
  id             String   @id @default(cuid())
  name           String
  description    String?
  organizationId String
  categoryId     String
  leaderId       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category     Category         @relation(fields: [categoryId], references: [id])
  leader       User?            @relation("TeamLeader", fields: [leaderId], references: [id])
  memberships  TeamMembership[]
  tasks        Task[]

  @@unique([organizationId, name])
}

model TaskTemplate {
  id             String   @id @default(cuid())
  name           String
  description    String?
  organizationId String
  categoryId     String?
  rrule          String?
  defaultMessage String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category     Category?    @relation(fields: [categoryId], references: [id])
  tasks        Task[]

  @@unique([organizationId, name])
}

model Task {
  id             String     @id @default(cuid())
  name           String
  description    String?
  scheduledAt    DateTime
  status         TaskStatus @default(DRAFT)
  organizationId String
  categoryId     String?
  teamId         String?
  templateId     String?
  createdById    String?
  isRecurring    Boolean    @default(false)
  recurrenceRule String?
  customMessage  String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category     Category?     @relation(fields: [categoryId], references: [id])
  team         Team?         @relation(fields: [teamId], references: [id])
  template     TaskTemplate? @relation(fields: [templateId], references: [id])
  createdBy    User?         @relation("TaskCreator", fields: [createdById], references: [id])
  assignments  Assignment[]
}

model Assignment {
  id          String           @id @default(cuid())
  taskId      String
  volunteerId String
  status      AssignmentStatus @default(PENDING)
  smsSentAt   DateTime?
  confirmedAt DateTime?
  declinedAt  DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  task      Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  volunteer Volunteer @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
  smsLogs   SmsLog[]

  @@unique([taskId, volunteerId])
}

model SmsLog {
  id           String       @id @default(cuid())
  toPhone      String
  fromPhone    String
  body         String
  direction    SmsDirection
  status       String
  twilioSid    String?
  simulated    Boolean      @default(false)
  errorMessage String?
  assignmentId String?
  volunteerId  String?
  sentById     String?
  createdAt    DateTime     @default(now())

  volunteer  Volunteer?  @relation(fields: [volunteerId], references: [id])
  assignment Assignment? @relation(fields: [assignmentId], references: [id])
  sentBy     User?       @relation("SentBy", fields: [sentById], references: [id])
}

// ─── NextAuth.js adapter models ───────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
